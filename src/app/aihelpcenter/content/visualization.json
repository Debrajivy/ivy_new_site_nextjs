                      {
                        "checked": true,
                        "text": "Always include units (₹, %, days)"
                      },
                      {
                        "checked": true,
                        "text": "Use distinct but restrained colors"
                      },
                      {
                        "checked": true,
                        "text": "Customize tooltips for each measure"
                      }
                    ]
                  },
                  {
                    "type": "warning",
                    "title": "Remember",
                    "content": "A dual-axis chart without clear labels is functionally useless."
                  }
